@page
@model checkpoint.Pages.VisitorsModel
@{
    ViewData["Title"] = "Гости";
}

<h2 class="mb-4">Добавить посетителя</h2>

<form method="post" class="card p-4 shadow-sm">

    <div class="form-group mb-2">
        <label>Имя:</label>
        <input asp-for="Visitor.Name" class="form-control" />
        <span asp-validation-for="Visitor.Name" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label>Фамилия:</label>
        <input asp-for="Visitor.Surname" class="form-control" />
        <span asp-validation-for="Visitor.Surname" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label>Отчество:</label>
        <input asp-for="Visitor.Patronymic" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label>Цель прохода:</label>
        <input asp-for="Purpose" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Сохранить</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
