@page
@using Microsoft.AspNetCore.Identity
@model checkpoint.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Login";
}
<h2>@ViewData["Title"]</h2>
<form method="post">
    <div class="form-group">
        <label for="Input_Email">Email</label>
        <input id="Input_Email" type="email" name="Input.Email" class="form-control" />
    </div>
    <div class="form-group">
        <label for="Input_Password">Пароль</label>
        <input id="Input_Password" type="password" name="Input.Password" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Логин</button>
</form>
<div>
    <a href="/Account/Register">У вас нет учетной записи? Зарегистрируйтесь здесь!</a>
</div>
