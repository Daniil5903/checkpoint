@page
@model checkpoint.Pages.StudentsModel
@{
    ViewData["Title"] = "Добавление студента";
}

<h2 class="mb-4">Добавить студента</h2>

<form method="post" class="card p-4 shadow-sm">
    <div class="form-group mb-2">
        <label>Имя:</label>
        <input asp-for="Student.Name" class="form-control" />
        <span asp-validation-for="Student.Name" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label>Фамилия:</label>
        <input asp-for="Student.Surname" class="form-control" />
        <span asp-validation-for="Student.Surname" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label>Отчество:</label>
        <input asp-for="Student.Patronymic" class="form-control" />
    </div>
    <div class="form-group mb-2">
        <label>Дата рождения:</label>
        <input asp-for="Student.BirthDay" type="date" class="form-control" />
    </div>
    <div class="form-group mb-2">
        <label>Группа:</label>
        <input asp-for="Student.Group" class="form-control" />
    </div>
    <div class="form-group mb-2">
        <label>Специальность:</label>
        <input asp-for="Student.Specialty" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label>Цель прохода:</label>
        <input asp-for="Purpose" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Сохранить</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}