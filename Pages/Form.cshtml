@page
@model checkpoint.Pages.FormModel
@{
    ViewData["Title"] = "Журнал проходящих через КПП";
}

<h2 class="mb-4">Журнал проходящих через КПП</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ФИО</th>
            <th>Тип</th>
            <th>Цель</th>
            <th>Дата и время входа</th>
            <th>Должность</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var pass in Model.Passes)
        {
            <tr>
                @if (Model.EditingPassId == pass.PassId)
                {
                    <td colspan="6">
                        <form method="post" asp-page-handler="Save">
                            <input type="hidden" name="passId" value="@pass.PassId" />

                            <div class="row">
                                <div class="col-md-3">
                                    <input asp-for="EditedSurname" class="form-control mb-1" placeholder="Фамилия" />
                                    <span asp-validation-for="EditedSurname" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    <input asp-for="EditedName" class="form-control mb-1" placeholder="Имя" />
                                    <span asp-validation-for="EditedName" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    <input asp-for="EditedPatronymic" class="form-control mb-1" placeholder="Отчество" />
                                    <span asp-validation-for="EditedPatronymic" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    @if (pass.OwnerType == "Employee")
                                    {
                                        <select asp-for="EditedPosition" class="form-select mb-1">
                                            <option value="">Выберите должность</option>
                                            <option>Преподаватель</option>
                                            <option>Директор</option>
                                            <option>Уборщик</option>
                                            <option>Охранник</option>
                                        </select>
                                        <span asp-validation-for="EditedPosition" class="text-danger"></span>
                                    }
                                </div>
                            </div>

                            <input asp-for="EditedPurpose" class="form-control mb-1" placeholder="Цель" />
                            <span asp-validation-for="EditedPurpose" class="text-danger"></span>

                            <button type="submit" class="btn btn-success btn-sm mt-2">Сохранить</button>
                        </form>
                    </td>
                }
                else
                {
                    <td>@pass.FullName</td>
                    <td>@pass.OwnerType</td>
                    <td>@pass.Purpose</td>
                    <td>@pass.IssueDate.ToString("dd.MM.yyyy HH:mm:ss")</td>
                    <td>@(pass.Position ?? "-")</td>
                    <td>
                        <form method="post" asp-page-handler="Edit" style="display:inline;">
                            <input type="hidden" name="passId" value="@pass.PassId" />
                            <button type="submit" class="btn btn-sm btn-warning">Изменить</button>
                        </form>
                        <form method="post" asp-page-handler="Delete" style="display:inline;">
                            <input type="hidden" name="passId" value="@pass.PassId" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить запись?')">Удалить</button>
                        </form>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
